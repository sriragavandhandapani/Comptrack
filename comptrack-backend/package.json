{
  "name": "comptrack-backend",
  "version": "1.0.0",
  "description": "CompTrack backend service for tracking competitor features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --coverage --watchAll=false --ci"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
